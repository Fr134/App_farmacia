generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String
  name        String
  role        String    @default("viewer")
  created_at  DateTime  @default(now())
  last_login  DateTime?

  sivat_assessments SivatAssessment[]
}

model Report {
  id              String   @id @default(cuid())
  filename        String
  file_hash       String   @unique
  period_month    Int
  period_year     Int
  uploaded_at     DateTime @default(now())

  total_revenue_gross Decimal @db.Decimal(12, 2)
  total_revenue_net   Decimal @db.Decimal(12, 2)
  total_iva           Decimal @db.Decimal(12, 2)
  total_cost          Decimal @db.Decimal(12, 2)
  total_margin        Decimal @db.Decimal(12, 2)
  total_margin_pct    Decimal @db.Decimal(5, 2)
  total_markup_pct    Decimal @db.Decimal(5, 2)
  total_pieces        Int
  total_sales         Int

  sectors SectorData[]

  @@unique([period_month, period_year])
}

model SectorData {
  id        String @id @default(cuid())
  report_id String
  report    Report @relation(fields: [report_id], references: [id], onDelete: Cascade)

  tipologia       String
  valore          Decimal  @db.Decimal(12, 2)
  valore_pct      Decimal? @db.Decimal(5, 2)
  media_pezzi     Decimal? @db.Decimal(8, 2)
  pezzi           Int      @default(0)
  pezzi_pct       Decimal? @db.Decimal(5, 2)
  n_vendite       Int      @default(0)
  vendite_pct     Decimal? @db.Decimal(5, 2)
  costo_venduto   Decimal? @db.Decimal(12, 2)
  margine         Decimal? @db.Decimal(12, 2)
  margine_tot_pct Decimal? @db.Decimal(5, 2)
  margine_pct     Decimal? @db.Decimal(6, 2)
  ricarico_pct    Decimal? @db.Decimal(6, 2)

  pezzi_ricetta      Int?     @default(0)
  pezzi_ricetta_pct  Decimal? @db.Decimal(5, 2)
  pezzi_libera       Int?     @default(0)
  pezzi_libera_pct   Decimal? @db.Decimal(5, 2)
  pezzi_fidelity     Int?     @default(0)
  pezzi_fidelity_pct Decimal? @db.Decimal(5, 2)
  valore_ricetta     Decimal? @db.Decimal(12, 2)
  valore_ricetta_pct Decimal? @db.Decimal(5, 2)
  valore_libera      Decimal? @db.Decimal(12, 2)
  valore_libera_pct  Decimal? @db.Decimal(5, 2)
  valore_fidelity    Decimal? @db.Decimal(12, 2)
  valore_fidelity_pct Decimal? @db.Decimal(5, 2)
  imponibile         Decimal? @db.Decimal(12, 2)
  imponibile_pct     Decimal? @db.Decimal(5, 2)
  iva                Decimal? @db.Decimal(12, 2)
  iva_pct            Decimal? @db.Decimal(5, 2)

  @@index([report_id])
}

// ─── SIVAT-D Assessment Module ───────────────────────

model SivatAssessment {
  id                String   @id @default(cuid())

  user_id           String
  user              User     @relation(fields: [user_id], references: [id])

  patient_name      String

  // Section scores (denormalized for fast querying)
  score_a           Int      // 0-20
  score_b           Int      // 0-25
  score_c           Int      // 0-15
  score_d           Int      // 0-15
  score_e           Int?     // 0-15 (null if section E disabled)
  section_e_enabled Boolean  @default(false)

  // Support index F (separate, not in total)
  support_level     Int?     // 0-3

  // Computed totals
  total_score       Int      // 0-100 (reparametrized if E excluded)
  raw_score         Int      // raw sum before reparametrization
  max_possible      Int      // 90 or 75

  // Classification
  classification    String   // ALTA, BUONA, PARZIALE, NON_ADERENZA

  // PDC data
  pdc_percentage    Decimal? @db.Decimal(5, 1)
  pdc_days_covered  Int?
  pdc_days_observed Int?

  // Full answers as JSON (for reconstruction/PDF regeneration)
  answers           Json     // Record<string, number | null>

  // Auto-generated results (stored for historical accuracy)
  criticalities     Json     // string[]
  interventions     Json     // string[]

  created_at        DateTime @default(now())

  @@index([user_id])
  @@index([patient_name])
  @@index([classification])
  @@index([created_at])
}

// ─── Enums ────────────────────────────────────────────

enum RecurrenceType {
  NONE
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum ExpenseSource {
  MANUAL
  INVOICE
  IMPORT
}

enum InstanceStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum InvoiceStatus {
  IMPORTED
  MATCHED
  RECONCILED
  REJECTED
}

// ─── Expense Module ───────────────────────────────────

model ExpenseCategory {
  id         String    @id @default(cuid())
  name       String    @unique
  color      String?
  icon       String?
  is_system  Boolean   @default(false)
  created_at DateTime  @default(now())

  expenses   Expense[]
}

model Supplier {
  id               String    @id @default(cuid())
  pharmacy_id      String
  ragione_sociale  String
  piva             String?
  codice_fiscale   String?
  sdi_code         String?
  iban             String?
  email            String?
  phone            String?
  notes            String?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  expenses         Expense[]

  @@index([pharmacy_id])
}

model Expense {
  id                String          @id @default(cuid())
  pharmacy_id       String

  name              String
  description       String?

  category_id       String
  category          ExpenseCategory @relation(fields: [category_id], references: [id])

  supplier_id       String?
  supplier          Supplier?       @relation(fields: [supplier_id], references: [id])

  amount_net        Decimal         @db.Decimal(10, 2)
  vat_rate          Decimal         @db.Decimal(5, 2)   @default(22)
  amount_gross      Decimal         @db.Decimal(10, 2)
  is_vat_deductible Boolean         @default(true)

  recurrence_type   RecurrenceType  @default(MONTHLY)
  is_fixed_cost     Boolean         @default(false)

  valid_from        DateTime
  valid_to          DateTime?

  source            ExpenseSource   @default(MANUAL)

  passive_invoice_id String?

  notes             String?

  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt
  deleted_at        DateTime?

  recurring_instances ExpenseRecurringInstance[]

  @@index([pharmacy_id])
  @@index([category_id])
  @@index([deleted_at])
}

model ExpenseRecurringInstance {
  id                   String         @id @default(cuid())
  expense_id           String
  expense              Expense        @relation(fields: [expense_id], references: [id], onDelete: Cascade)

  period_month         DateTime
  amount_net_override  Decimal?       @db.Decimal(10, 2)

  status               InstanceStatus @default(ACTIVE)
  created_at           DateTime       @default(now())

  @@unique([expense_id, period_month])
  @@index([expense_id])
}

model PassiveInvoice {
  id              String        @id @default(cuid())
  pharmacy_id     String

  supplier_id     String?

  sdi_id          String?
  invoice_number  String?
  invoice_date    DateTime?

  taxable_amount  Decimal?      @db.Decimal(10, 2)
  vat_amount      Decimal?      @db.Decimal(10, 2)
  total_amount    Decimal?      @db.Decimal(10, 2)

  xml_raw         String?       @db.Text

  status          InvoiceStatus @default(IMPORTED)

  expense_id      String?

  imported_at     DateTime      @default(now())
  created_at      DateTime      @default(now())

  @@index([pharmacy_id])
  @@index([status])
}

// ─── Budget Module Enums ─────────────────────────────

enum BudgetStatus {
  DRAFT
  CONFIRMED
  ARCHIVED
}

enum BaselineSource {
  HISTORICAL
  MANUAL
}

enum AdjustmentMode {
  PCT_CHANGE
  ABSOLUTE
  NO_CHANGE
}

// ─── Budget Module ───────────────────────────────────

model Budget {
  id              String          @id @default(cuid())
  pharmacyId      String

  name            String          // e.g. "Budget 2026 - Base scenario"
  year            Int
  status          BudgetStatus    @default(DRAFT)

  // How the baseline was built
  baselineSource  BaselineSource  @default(HISTORICAL)
  baselineYear    Int?            // e.g. 2025 — which historical year was used

  // Optional: global revenue adjustment (used when user picks "simple mode")
  // If set, all BudgetRevenueLine adjustments are overridden by this value
  globalAdjustmentPct  Decimal?   @db.Decimal(6, 2)

  notes           String?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  revenueLines    BudgetRevenueLine[]
  expenseLines    BudgetExpenseLine[]

  @@index([pharmacyId, year])
}

// Each row represents one product category (e.g. "Farmaco etico").
// baselineMarginPct is LOCKED — it comes from historical data and cannot be
// changed by the user. It drives COGS and margin calculations automatically.
model BudgetRevenueLine {
  id                  String          @id @default(cuid())
  budgetId            String
  budget              Budget          @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  // Product category label (matches CSV tipologia)
  categoryLabel       String          // e.g. "Farmaco etico"

  // Baseline values — read-only, sourced from historical CSV data
  baselineRevenue     Decimal         @db.Decimal(12, 2)
  baselineMarginPct   Decimal         @db.Decimal(8, 4)   // e.g. 27.6900 — LOCKED
  baselinePieces      Int?

  // Adjustment applied by the user
  adjustmentMode      AdjustmentMode  @default(PCT_CHANGE)
  adjustmentPct       Decimal?        @db.Decimal(6, 2)   // e.g. 10.00 = +10%
  adjustmentAbsolute  Decimal?        @db.Decimal(12, 2)  // used if mode = ABSOLUTE

  // Forecast values — derived fields, recalculated on every save
  forecastRevenue     Decimal         @db.Decimal(12, 2)
  forecastCOGS        Decimal         @db.Decimal(12, 2)  // forecastRevenue * (1 - marginPct/100)
  forecastMargin      Decimal         @db.Decimal(12, 2)  // forecastRevenue * marginPct/100

  sortOrder           Int             @default(0)

  @@unique([budgetId, categoryLabel])
  @@index([budgetId])
}

// Operating costs entered in the budget.
// isStructural = true means the cost is auto-imported and cannot be deleted
// (e.g. fixed costs already entered in the Expenses module).
model BudgetExpenseLine {
  id              String          @id @default(cuid())
  budgetId        String
  budget          Budget          @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  // Optional link to an existing Expense record
  expenseId       String?         // FK to Expense — null if standalone budget line

  name            String
  categoryLabel   String          // e.g. "Rent", "Staff"
  amountNet       Decimal         @db.Decimal(10, 2)
  vatRate         Decimal         @db.Decimal(5, 2)   @default(22)
  amountGross     Decimal         @db.Decimal(10, 2)
  recurrenceType  RecurrenceType  // reuse enum from Expenses module

  // Annual total — computed from amountNet + recurrenceType
  annualAmountNet Decimal         @db.Decimal(10, 2)

  // If true: auto-imported from Expenses module, cannot be deleted by user
  isStructural    Boolean         @default(false)

  notes           String?
  sortOrder       Int             @default(0)

  @@index([budgetId])
}
